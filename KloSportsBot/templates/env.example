# Environment template — copy to .env (gitignored) at the repo root and fill in.
#   cp templates/env.example .env
# Then `set -a; . ./.env; set +a` (or use your shell's dotenv loader) before running scripts.
# NEVER commit your filled-in .env. See SECURITY.md.

# ---- Pool login (used by browser/login.example.mjs to mint browser/auth.json) ----
POOL_EMAIL=you@example.com
POOL_PASSWORD=change-me

# ---- Pool site (also set in browser/config.json) ----
# Base URL of your prediction-pool site. KGP97's Vercel app is the reference; swap freely.
POOL_BASE=https://your-pool.example.com

# ---- WhatsApp bridge identifiers (mirror of bridge/bridge.config.sh) ----
# Your note-to-self thread target (where send_self.sh delivers replies).
SELF_DM_TARGET=<YOUR_PHONE>@s.whatsapp.net
# All identifiers the listener treats as "self" (comma-separated; usually LID + phone JID).
BRIDGE_SELF_IDS=<YOUR_LID>@lid,<YOUR_PHONE>@s.whatsapp.net
# The pool group you post coverage to (*@g.us).
BRIDGE_GROUP_JID=<YOUR_GROUP_ID>@g.us
# Local webhook + port for the bridge (rarely need changing).
BRIDGE_WEBHOOK=http://127.0.0.1:8787/
BRIDGE_PORT=8787

# ---- Agent persona (optional; mirrors skill/persona/IDENTITY.md) ----
AGENT_NAME=YourAgent
AGENT_EMOJI=🤖
